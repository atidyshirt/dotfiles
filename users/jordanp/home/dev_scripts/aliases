# Dev aliases — sourced from ~/.zshrc (Home Manager: ~/dev_scripts/).
# Atuin: programs.atuin.enableZshIntegration (atuin module). Completions: programs.zsh.enableCompletion.

source "$HOME/dev_scripts/utils"

alias ..='cd ..'
alias ...='cd ../..'
case "$OSTYPE" in
  darwin*) alias ls='ls -G' ;;
  *) alias ls='ls --color=auto' ;;
esac

if doesCommandExist nvim; then
  alias vi='nvim'
  alias svi='sudo nvim'
  alias vgit='nvim -c :0G'
  alias arc='nvim ~/dev_scripts/aliases'
  alias trc='nvim ~/.config/kitty/kitty.conf'
  alias zrc='nvim ~/.zshrc'
fi

if doesCommandExist lazygit; then
  alias lg='lazygit'
fi

if doesCommandExist lazydocker; then
  alias ld='lazydocker'
fi

autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^e' edit-command-line

if doesCommandExist git; then
  alias gc='git clone'
  alias glog="git log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --branches"
fi

if doesCommandExist orb; then
  # OrbStack installs shell hooks under ~/.orbstack when the app has run once.
  source ~/.orbstack/shell/init.zsh 2>/dev/null || :
fi

if doesCommandExist tmux; then
  alias ts='tmux a || tmux new-session -s workspace'
  alias curl-atlnz='curl --socks5-hostname localhost:1080'
fi
